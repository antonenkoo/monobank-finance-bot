# ── Telegram ──────────────────────────────────────────────────────────────────
# Получи токен у @BotFather
TELEGRAM_BOT_TOKEN=

# Заполняется автоматически при первом /start
TELEGRAM_CHAT_ID=

# ── Monobank ──────────────────────────────────────────────────────────────────
# Личный токен: https://api.monobank.ua/
MONOBANK_TOKEN=

# ID аккаунта (можно выбрать через /config → "Выбрать аккаунт")
MONOBANK_ACCOUNT_ID=

# ── Notion ────────────────────────────────────────────────────────────────────
# Internal Integration Secret: https://www.notion.so/my-integrations
NOTION_API_KEY=

# ID базы данных транзакций (32 символа из URL)
NOTION_TRANSACTIONS_DB_ID=

# ID базы данных категорий (32 символа из URL)
NOTION_CATEGORIES_DB_ID=

# ── Ngrok ─────────────────────────────────────────────────────────────────────
# Auth Token с https://dashboard.ngrok.com/ (опционально)
NGROK_AUTH_TOKEN=

# ── Прочее ────────────────────────────────────────────────────────────────────
# Порт для webhook-сервера
WEBHOOK_PORT=8080

# Режим отладки: true = отправлять сообщения о транзакциях, false = тихий режим
DEBUG_MODE=false
